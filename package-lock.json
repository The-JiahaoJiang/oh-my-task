{
  "name": "oh-my-task",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "oh-my-task",
      "version": "0.0.0",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/oh-my-task-cli": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/oh-my-task-pi": {
      "resolved": "packages/pi-extension",
      "link": true
    },
    "packages/core": {
      "name": "oh-my-task-cli",
      "version": "0.1.0",
      "bin": {
        "oh-my-task-cli": "dist/cli.js"
      }
    },
    "packages/pi-extension": {
      "name": "oh-my-task-pi",
      "version": "0.1.0",
      "dependencies": {
        "oh-my-task-cli": "*"
      },
      "peerDependencies": {
        "@earendil-works/pi-ai": "*",
        "@earendil-works/pi-coding-agent": "*",
        "typebox": "*"
      },
      "peerDependenciesMeta": {
        "@earendil-works/pi-ai": {
          "optional": true
        },
        "@earendil-works/pi-coding-agent": {
          "optional": true
        },
        "typebox": {
          "optional": true
        }
      }
    }
  }
}
